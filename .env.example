# Critsend — Environment Variables
# Copy this file to .env and fill in the values before running on a self-hosted server.
# Lines starting with # are comments. Lines marked [REQUIRED] must be set.
# Lines marked [OPTIONAL] have a default or are only needed for specific features.

# ─── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string (Neon or any PostgreSQL server)
# Format: postgres://user:password@host:5432/dbname?sslmode=require
NEON_DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# [OPTIONAL] Fallback database URL if NEON_DATABASE_URL is not set
# DATABASE_URL=postgres://user:password@localhost:5432/critsend

# [OPTIONAL] Force SSL for database connections (auto-detected from hostname)
# DB_SSL=true

# ─── Redis ─────────────────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL for BullMQ job queues and SSE pub/sub
# Upstash: rediss://default:password@host.upstash.io:6379
# Local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# [OPTIONAL] Enable BullMQ (defaults to true when REDIS_URL is set)
# USE_BULLMQ=true

# ─── Session & Security ─────────────────────────────────────────────────────────

# [REQUIRED] Secret used to sign session cookies — use a long random string
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# [REQUIRED] Secret for HMAC-signing tracking URLs (open/click)
# Generate with: openssl rand -hex 32
TRACKING_SECRET=change-me-to-a-long-random-string

# [REQUIRED] AES-256-GCM encryption key for SMTP passwords at rest
# Generate with: openssl rand -hex 32
MTA_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# [OPTIONAL] Secret for validating incoming bounce webhooks
# WEBHOOK_SECRET=your-webhook-secret

# ─── Server ────────────────────────────────────────────────────────────────────

# [OPTIONAL] HTTP port the Express server listens on (default: 5000)
# PORT=5000

# [OPTIONAL] Comma-separated allowed CORS origins (defaults to same-origin only)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# [OPTIONAL] Node.js heap size limit (default: 8192 MB)
# NODE_OPTIONS=--max-old-space-size=8192 --expose-gc

# ─── Storage ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Storage backend for CSV import files.
# "local"  — files stay in uploads/imports/ on disk (default, works on any server)
# "replit" — files are uploaded to Replit Object Storage (Replit environments only)
STORAGE_BACKEND=local

# The following are only needed when STORAGE_BACKEND=replit:
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket-name/public
# PRIVATE_OBJECT_DIR=/bucket-name/.private
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id

# ─── Email (Resend — for test emails only) ──────────────────────────────────────

# [OPTIONAL] Resend API key for sending test emails when no MTA is selected.
# Only needed if you use the "Send test email" feature without an SMTP server.
# Sign up at https://resend.com — free tier sends 100 emails/day.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Default "from" address used for Resend test emails
# Must be a verified sender in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Connection Pool Tuning ────────────────────────────────────────────────────
# Only adjust these if you know what you are doing.
# Default values are tuned for Neon's 50-connection limit.
# Increase PG_POOL_MAX if using a local PostgreSQL server (no connection limit).

# [OPTIONAL] Max DB connections for the web process (default: 20)
# WEB_PG_POOL_MAX=20

# [OPTIONAL] Max DB connections for the worker process (default: 8)
# WORKER_PG_POOL_MAX=8

# [OPTIONAL] Max DB connections for import workers (default: 4)
# PG_IMPORT_POOL_MAX=4

# [OPTIONAL] Import worker concurrency (default: 4)
# PG_IMPORT_CONCURRENCY=4

# [OPTIONAL] Headroom reserve connections (default: 12)
# PG_HEADROOM_RESERVE=12

# ─── SMTP / Sending ────────────────────────────────────────────────────────────

# [OPTIONAL] Skip TLS certificate verification for SMTP connections (dev only!)
# SMTP_SKIP_TLS_VERIFY=false

# ─── Environment ───────────────────────────────────────────────────────────────

# [REQUIRED] Node.js environment
NODE_ENV=production

# [OPTIONAL] Process type — set automatically by the launcher / PM2 config
# PROCESS_TYPE=web   (web server process)
# PROCESS_TYPE=worker  (background worker process)
