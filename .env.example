# Critsend — Environment Variables
# Copy this file to .env and fill in the values before running on a self-hosted server.
# Lines starting with # are comments. Lines marked [REQUIRED] must be set.
# Lines marked [OPTIONAL] have a default or are only needed for specific features.

# ─── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string (Neon or any PostgreSQL server)
# Format: postgres://user:password@host:5432/dbname?sslmode=require
# IMPORTANT: Wrap the value in double quotes if it contains & (e.g. Neon pooler URLs with
# &channel_binding=require). Unquoted & is interpreted by bash as a background-job operator.
# Example: NEON_DATABASE_URL="postgres://user:pass@host/db?sslmode=require&channel_binding=require"
NEON_DATABASE_URL="postgres://user:password@host/dbname?sslmode=require"

# [OPTIONAL] Fallback database URL used when NEON_DATABASE_URL is not set
# DATABASE_URL=postgres://user:password@localhost:5432/critsend

# [OPTIONAL] Force SSL for database connections (auto-detected from hostname when unset)
# DB_SSL=true

# ─── Redis ─────────────────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL for BullMQ job queues and SSE pub/sub
# Upstash: rediss://default:password@host.upstash.io:6379
# Local:   redis://localhost:6379
REDIS_URL=redis://localhost:6379

# [OPTIONAL] Enable BullMQ (defaults to true when REDIS_URL is set)
# USE_BULLMQ=true

# ─── Session & Security ─────────────────────────────────────────────────────────

# [REQUIRED] Secret used to sign session cookies — use a long random string
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# [REQUIRED] Secret for HMAC-signing tracking URLs (open/click)
# Generate with: openssl rand -hex 32
TRACKING_SECRET=change-me-to-a-long-random-string

# [REQUIRED] AES-256-GCM encryption key for SMTP passwords at rest
# Generate with: openssl rand -hex 32
MTA_ENCRYPTION_KEY=change-me-to-a-64-char-hex-string

# [OPTIONAL] Secret for validating incoming bounce webhooks
# WEBHOOK_SECRET=your-webhook-secret

# ─── Server ────────────────────────────────────────────────────────────────────

# [REQUIRED] Public base URL of this server — used as a fallback to make campaign
# image URLs absolute in sent emails when an MTA has no Image Hosting Domain set.
# Must be the HTTPS origin reachable by email clients (no trailing slash).
# Example: PUBLIC_URL=https://server.critsender.com
PUBLIC_URL=https://server.critsender.com

# [OPTIONAL] HTTP port the Express server listens on (default: 5000)
# PORT=5000

# [OPTIONAL] Node.js environment — set to "production" on a dedicated server
NODE_ENV=production

# [OPTIONAL] Comma-separated allowed CORS origins (defaults to same-origin only)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# [OPTIONAL] Node.js heap size and GC options
# NODE_OPTIONS=--max-old-space-size=4096 --expose-gc

# [OPTIONAL] Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info

# ─── Process Architecture ──────────────────────────────────────────────────────

# [OPTIONAL] Process type — set automatically by the PM2 ecosystem config or dev-launcher.
# Do not set manually unless you are starting web/worker processes independently.
# PROCESS_TYPE=web      (HTTP server + SSE)
# PROCESS_TYPE=worker   (background job processor)

# [OPTIONAL] Set to "true" to prevent this instance from starting background workers.
# Use when a Replit-published app shares a Neon DB with a self-hosted PM2 deployment.
# Without this, the Replit monolith will pick up import jobs uploaded on the PM2 server
# and fail because the CSV files only exist on the PM2 server's local filesystem.
# DISABLE_WORKERS=true

# ─── Storage ───────────────────────────────────────────────────────────────────

# [OPTIONAL] Storage backend for CSV import files.
# "local"  — files stay in uploads/imports/ on disk (default, works on any server)
# "replit" — files are uploaded to Replit Object Storage (Replit environments only)
STORAGE_BACKEND=local

# The following are only needed when STORAGE_BACKEND=replit (Replit-managed):
# PUBLIC_OBJECT_SEARCH_PATHS=/bucket-name/public
# PRIVATE_OBJECT_DIR=/bucket-name/.private
# DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-bucket-id

# ─── Email (Resend — for test emails only) ──────────────────────────────────────

# [OPTIONAL] Resend API key for sending test emails when no MTA is selected.
# Only needed if you use the "Send test email" feature without a configured SMTP server.
# Sign up at https://resend.com — free tier sends 100 emails/day.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Default "from" address used for Resend test emails.
# Must be a verified sender domain in your Resend account.
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Connection Pool Tuning ────────────────────────────────────────────────────
# Only adjust these if you know what you are doing.
# Default values are tuned for Neon's 50-connection limit.
# On a local PostgreSQL server with no connection limit, you can raise these.

# [OPTIONAL] Total PostgreSQL connection limit for budget calculations (default: 50)
# Increase this if your PostgreSQL server supports more connections.
# PG_CONNECTION_LIMIT=50

# [OPTIONAL] Max DB connections for the monolith fallback pool (default: auto-calculated)
# PG_POOL_MAX=33

# [OPTIONAL] Max DB connections for the web process (default: 20)
# WEB_PG_POOL_MAX=20

# [OPTIONAL] Max DB connections for the worker process (default: 8).
# Raise to 14 when MAX_CONCURRENT_CAMPAIGNS > 5 to avoid pool saturation.
# WORKER_PG_POOL_MAX=14

# [OPTIONAL] Maximum number of campaigns processed in parallel by the worker (default: 8).
# Each extra campaign adds ~1-2 peak DB connections against WORKER_PG_POOL_MAX.
# Recommended: keep WORKER_PG_POOL_MAX >= MAX_CONCURRENT_CAMPAIGNS + 6.
# MAX_CONCURRENT_CAMPAIGNS=8

# [OPTIONAL] Max DB connections for import workers (default: 4)
# PG_IMPORT_POOL_MAX=4

# [OPTIONAL] Import worker concurrency — number of parallel import streams (default: 4)
# PG_IMPORT_CONCURRENCY=4

# [OPTIONAL] Headroom reserve connections kept free to prevent cascade timeouts (default: 12)
# PG_HEADROOM_RESERVE=12

# ─── SMTP / Sending ────────────────────────────────────────────────────────────

# [OPTIONAL] Skip TLS certificate verification for SMTP connections.
# Set to "true" only in development — NEVER in production.
# SMTP_SKIP_TLS_VERIFY=false

# ─── Replit-Specific (leave unset on self-hosted servers) ─────────────────────
# These variables are set automatically by the Replit platform.
# You do not need to set them on a dedicated server.

# Replit Connectors service hostname (used for Resend integration on Replit)
# REPLIT_CONNECTORS_HOSTNAME=connectors.replit.com

# Replit workspace identity token (used by Resend connector auth on Replit)
# REPL_IDENTITY=<set by Replit platform>

# Replit deployment renewal token (used by Resend connector auth on deployed Replit apps)
# WEB_REPL_RENEWAL=<set by Replit platform>
